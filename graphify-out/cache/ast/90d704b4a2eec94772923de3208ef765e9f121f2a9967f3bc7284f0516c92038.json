.find((a: any) => a.value === 'sales_owner_id')) {\r\n            commonAttrs.push({ label: 'Lead Owner', value: 'sales_owner_id' });\r\n        }\r\n\r\n        return [...industryAttrs, ...commonAttrs];\r\n    })", "is_member_call": false, "source_file": "C:\\Users\\ppdub\\Documents\\Work\\Weskill\\Software\\FastestCRM\\src\\pages\\FormBuilder.tsx", "source_location": "L253"}, {"caller_nid": "pages_formbuilder_formbuilder", "callee": "useForm", "is_member_call": false, "source_file": "C:\\Users\\ppdub\\Documents\\Work\\Weskill\\Software\\FastestCRM\\src\\pages\\FormBuilder.tsx", "source_location": "L297"}, {"caller_nid": "pages_formbuilder_formbuilder", "callee": "useCreateForm", "is_member_call": false, "source_file": "C:\\Users\\ppdub\\Documents\\Work\\Weskill\\Software\\FastestCRM\\src\\pages\\FormBuilder.tsx", "source_location": "L298"}, {"caller_nid": "pages_formbuilder_formbuilder", "callee": "useUpdateForm", "is_member_call": false, "source_file": "C:\\Users\\ppdub\\Documents\\Work\\Weskill\\Software\\FastestCRM\\src\\pages\\FormBuilder.tsx", "source_location": "L299"}, {"caller_nid": "pages_formbuilder_formbuilder", "callee": "useUserRole", "is_member_call": false, "source_file": "C:\\Users\\ppdub\\Documents\\Work\\Weskill\\Software\\FastestCRM\\src\\pages\\FormBuilder.tsx", "source_location": "L300"}, {"caller_nid": "pages_formbuilder_formbuilder", "callee": "useState", "is_member_call": false, "source_file": "C:\\Users\\ppdub\\Documents\\Work\\Weskill\\Software\\FastestCRM\\src\\pages\\FormBuilder.tsx", "source_location": "L302"}, {"caller_nid": "pages_formbuilder_formbuilder", "callee": "useState", "is_member_call": false, "source_file": "C:\\Users\\ppdub\\Documents\\Work\\Weskill\\Software\\FastestCRM\\src\\pages\\FormBuilder.tsx", "source_location": "L303"}, {"caller_nid": "pages_formbuilder_formbuilder", "callee": "useState", "is_member_call": false, "source_file": "C:\\Users\\ppdub\\Documents\\Work\\Weskill\\Software\\FastestCRM\\src\\pages\\FormBui